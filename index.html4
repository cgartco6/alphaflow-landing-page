<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AlphaFlow | Engineering Male Performance</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@1,600&family=Montserrat:wght@300;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --black-matte: #080808;
            --charcoal: #121212;
            /* The "Million Dollar" Gold - Not yellow, but Metallic Champagne */
            --gold-gradient: linear-gradient(135deg, #8E6E2E 0%, #D4AF37 45%, #F7E7CE 70%, #C5A059 100%);
            --gold-solid: #D4AF37;
            --glass: rgba(255, 255, 255, 0.03);
            --border: rgba(212, 175, 55, 0.2);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background-color: var(--black-matte); color: #fff; font-family: 'Montserrat', sans-serif; line-height: 1.7; overflow-x: hidden; }

        /* Navigation */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 25px 8%;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            background: rgba(8, 8, 8, 0.8);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border);
        }

        .logo { font-weight: 800; font-size: 1.4rem; letter-spacing: 4px; background: var(--gold-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        
        .nav-items { display: flex; gap: 40px; align-items: center; }
        .nav-items a { text-decoration: none; color: #fff; font-size: 0.75rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; transition: 0.3s; opacity: 0.7; }
        .nav-items a:hover { opacity: 1; color: var(--gold-solid); }

        .hamburger { display: none; color: var(--gold-solid); font-size: 1.5rem; }

        /* Hero Section */
        .hero {
            height: 100vh;
            display: flex;
            align-items: center;
            padding: 0 10%;
            position: relative;
            background: radial-gradient(circle at 70% 50%, #1a1a1a 0%, #080808 100%);
        }

        .hero-content { flex: 1; z-index: 2; }
        .hero-content span { color: var(--gold-solid); letter-spacing: 5px; font-weight: 600; font-size: 0.8rem; }
        .hero-content h1 { font-size: clamp(3rem, 8vw, 5.5rem); line-height: 0.9; margin: 20px 0; font-weight: 800; }
        .hero-content p { font-size: 1.1rem; color: #999; max-width: 500px; margin-bottom: 40px; }

        /* 3D Bottle Concept (Pure CSS) */
        .hero-visual { flex: 1; display: flex; justify-content: center; position: relative; }
        .bottle {
            width: 260px;
            height: 450px;
            background: linear-gradient(135deg, #111 0%, #222 50%, #000 100%);
            border-radius: 20px 20px 80px 80px;
            box-shadow: 0 50px 100px rgba(0,0,0,0.8), inset 0 0 20px rgba(255,255,255,0.05);
            position: relative;
            border: 1px solid #333;
            transform: rotate(-5deg);
            transition: 0.5s ease;
        }
        .bottle:hover { transform: rotate(0deg) scale(1.02); }
        .label {
            position: absolute;
            top: 35%; width: 100%; height: 140px;
            background: var(--gold-gradient);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: #000;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .label h2 { font-size: 1.5rem; font-weight: 900; letter-spacing: 2px; }
        
        /* Buttons */
        .cta-btn {
            background: var(--gold-gradient);
            color: #000;
            padding: 20px 45px;
            text-decoration: none;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-size: 0.8rem;
            border-radius: 2px;
            transition: 0.4s;
            display: inline-block;
        }
        .cta-btn:hover { transform: translateY(-5px); box-shadow: 0 20px 40px rgba(212, 175, 55, 0.2); }

        /* Product Section */
        .section { padding: 120px 10%; text-align: center; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-top: 60px; }
        
        .product-card {
            background: var(--charcoal);
            padding: 60px 40px;
            border: 1px solid var(--border);
            border-radius: 4px;
            transition: 0.4s;
            position: relative;
            overflow: hidden;
        }
        .product-card::before {
            content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
            transition: 0.5s;
        }
        .product-card:hover::before { left: 100%; }
        .product-card:hover { border-color: var(--gold-solid); transform: translateY(-10px); }

        .price-tag { font-size: 1.8rem; font-weight: 300; margin: 20px 0; color: var(--gold-solid); }

        /* Mobile */
        @media (max-width: 900px) {
            .nav-items { display: none; }
            .hamburger { display: block; }
            .hero { flex-direction: column; text-align: center; justify-content: center; padding-top: 100px; }
            .hero-visual { margin-top: 60px; }
            .bottle { width: 180px; height: 320px; }
        }
    </style>
</head>
<body>

    <nav>
        <div class="logo">ALPHAFLOW</div>
        <div class="nav-items">
            <a href="#science">The Science</a>
            <a href="#products">The System</a>
            <a href="#tester">Tester Program</a>
            <a href="#" class="cta-btn" style="padding: 12px 25px;">Shop Now</a>
        </div>
        <div class="hamburger"><i class="fas fa-bars"></i></div>
    </nav>

    <section class="hero">
        <div class="hero-content">
            <span>EVOLVED MALE VITALITY</span>
            <h1>Be ready when it matters.</h1>
            <p>A precision-engineered performance system designed for the man who demands more from his body and mind.</p>
            <a href="#products" class="cta-btn">Experience AlphaFlow</a>
        </div>
        <div class="hero-visual">
            <div class="bottle">
                <div class="label">
                    <h2>ALPHAFLOW</h2>
                    <p style="font-size: 0.6rem; font-weight: 700;">PREMIUM SUPPLEMENTS</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section" id="products">
        <span style="color: var(--gold-solid); letter-spacing: 3px;">THE COLLECTION</span>
        <h2 style="font-size: 3rem; margin-top: 10px;">The Performance System</h2>
        
        <div class="grid">
            <div class="product-card">
                <div class="bottle" style="width: 100px; height: 180px; margin: 0 auto 30px; transform: none;">
                    <div class="label" style="height: 60px;"><h2 style="font-size: 0.7rem;">PRE-SHOT</h2></div>
                </div>
                <h3>PRE-SHOT ELIXIR</h3>
                <p style="color: #666; font-size: 0.9rem; margin-top: 10px;">Nitric Oxide & Blood Flow Catalyst</p>
                <div class="price-tag">R499.00</div>
                <a href="#" class="cta-btn" style="width: 100%;">Add to Cart</a>
            </div>

            <div class="product-card">
                <div class="bottle" style="width: 100px; height: 180px; margin: 0 auto 30px; transform: none;">
                    <div class="label" style="height: 60px;"><h2 style="font-size: 0.7rem;">CORE CAPS</h2></div>
                </div>
                <h3>CORE CAPSULES</h3>
                <p style="color: #666; font-size: 0.9rem; margin-top: 10px;">Daily Hormonal & Energy Support</p>
                <div class="price-tag">R599.00</div>
                <a href="#" class="cta-btn" style="width: 100%;">Add to Cart</a>
            </div>
        </div>
    </section>

    <footer style="padding: 60px; border-top: 1px solid #222; text-align: center; color: #444;">
        <p>&copy; 2026 ALPHAFLOW PRECISION LABORATORY. SOUTH AFRICA.</p>
    </footer>

</body>
</html>
